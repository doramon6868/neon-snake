+        function createCherryTreeAnimation() {
+            // 樱桃树在左侧，高度为游戏区一半，底部对齐，带有抖动动画
+            const canvas = document.getElementById('gameCanvas');
+            const canvasRect = canvas.getBoundingClientRect();
+
+            // 计算樱桃树大小（游戏区高度的1/2）
+            const cherryTreeHeight = canvasRect.height * 0.5;
+            const cherryTreeFontSize = cherryTreeHeight * 0.8;
+
+            // 创建樱桃树（由于没有樱桃树emoji，使用树emoji 🌳 + 樱桃emoji 🍒）
+            const cherryTreeContainer = document.createElement('div');
+            cherryTreeContainer.style.cssText = `
+                position: fixed;
+                left: ${canvasRect.left - cherryTreeHeight * 0.8}px;
+                top: ${canvasRect.bottom - cherryTreeHeight}px;
+                width: ${cherryTreeHeight}px;
+                height: ${cherryTreeHeight}px;
+                pointer-events: none;
+                z-index: 150;
+                animation: cherry-tree-shake 2s ease-in-out;
+                overflow: visible;
+            `;
+
+            // 创建树干（褐色）
+            const trunk = document.createElement('div');
+            trunk.style.cssText = `
+                position: absolute;
+                bottom: 0;
+                left: 50%;
+                transform: translateX(-50%);
+                width: ${cherryTreeHeight * 0.15}px;
+                height: ${cherryTreeHeight * 0.4}px;
+                background: #8B4513;
+                border-radius: 5px;
+                z-index: 1;
+            `;
+
+            // 创建树冠（绿色）
+            const crown = document.createElement('div');
+            crown.textContent = '🌳';
+            crown.style.cssText = `
+                position: absolute;
+                bottom: ${cherryTreeHeight * 0.25}px;
+                left: 50%;
+                transform: translateX(-50%);
+                font-size: ${cherryTreeFontSize}px;
+                z-index: 2;
+                line-height: 1;
+                transform-origin: bottom center;
+            `;
+
+            // 创建樱桃emoji
+            const cherries = [];
+            for (let i = 0; i < 8; i++) {
+                const cherry = document.createElement('div');
+                cherry.textContent = '🍒';
+                const angle = (Math.PI * 2 * i) / 8;
+                const radius = cherryTreeHeight * 0.2;
+                const x = Math.cos(angle) * radius;
+                const y = Math.sin(angle) * radius - cherryTreeHeight * 0.3;
+
+                cherry.style.cssText = `
+                    position: absolute;
+                    bottom: ${cherryTreeHeight * 0.45 + y}px;
+                    left: 50%;
+                    transform: translateX(calc(-50% + ${x}px));
+                    font-size: ${cherryTreeHeight * 0.15}px;
+                    z-index: 3;
+                    animation: cherry-bounce 0.5s ${i * 0.1}s infinite alternate;
+                `;
+
+                // 添加樱桃弹跳动画
+                const bounceStyle = document.createElement('style');
+                bounceStyle.textContent = `
+                    @keyframes cherry-bounce {
+                        0% { transform: translateX(calc(-50% + ${x}px)) translateY(0); }
+                        100% { transform: translateX(calc(-50% + ${x}px)) translateY(-5px); }
+                    }
+                `;
+                document.head.appendChild(bounceStyle);
+                cherries.push({element: cherry, style: bounceStyle});
+                crown.appendChild(cherry);
+            }
+
+            const style = document.createElement('style');
+            style.textContent = `
+                @keyframes cherry-tree-shake {
+                    0%, 100% { transform: translateX(0) rotate(0deg); }
+                    10% { transform: translateX(-5px) rotate(-2deg); }
+                    20% { transform: translateX(5px) rotate(2deg); }
+                    30% { transform: translateX(-3px) rotate(-1deg); }
+                    40% { transform: translateX(3px) rotate(1deg); }
+                    50% { transform: translateX(-2px) rotate(-1deg); }
+                    60% { transform: translateX(2px) rotate(1deg); }
+                    70% { transform: translateX(-1px) rotate(0deg); }
+                    80% { transform: translateX(1px) rotate(0deg); }
+                    90% { transform: translateX(0) rotate(0deg); }
+                }
+            `;
+            document.head.appendChild(style);
+
+            cherryTreeContainer.appendChild(trunk);
+            cherryTreeContainer.appendChild(crown);
+            document.body.appendChild(cherryTreeContainer);
+
+            setTimeout(() => {
+                cherryTreeContainer.remove();
+                document.head.removeChild(style);
+                cherries.forEach(c => {
+                    if (document.head.contains(c.style)) {
+                        document.head.removeChild(c.style);
+                    }
+                });
+            }, 3000);
         }
 
         function restartGame() {
