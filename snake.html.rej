+        function activateCherryTree() {
+            // 随机出现5-15个樱桃
+            const { tileCount } = getGameSettings();
+            const cherryCount = 5 + Math.floor(Math.random() * 11); // 5-15个樱桃
+            const cherryData = fruitTypes.find(f => f.emoji === '🍒'); // 找到樱桃数据
+
+            // 生成随机位置（围绕游戏区周围）
+            const cherryPositions = [];
+            for (let i = 0; i < cherryCount; i++) {
+                let pos = {
+                    x: Math.floor(Math.random() * tileCount),
+                    y: Math.floor(Math.random() * tileCount)
+                };
+
+                // 检查位置是否有效
+                let valid = true;
+                for (let segment of snake) {
+                    if (segment.x === pos.x && segment.y === pos.y) {
+                        valid = false;
+                        break;
+                    }
+                }
+
+                for (let existingFood of foods) {
+                    if (existingFood.x === pos.x && existingFood.y === pos.y) {
+                        valid = false;
+                        break;
+                    }
+                }
+
+                for (let existingPos of cherryPositions) {
+                    if (existingPos.x === pos.x && existingPos.y === pos.y) {
+                        valid = false;
+                        break;
+                    }
+                }
+
+                if (valid) {
+                    cherryPositions.push(pos);
+                } else {
+                    i--; // 重试
+                }
+            }
+
+            // 延迟添加樱桃，配合动画效果
+            cherryPositions.forEach((pos, index) => {
+                setTimeout(() => {
+                    // 检查位置是否仍然有效
+                    let stillValid = true;
+                    for (let segment of snake) {
+                        if (segment.x === pos.x && segment.y === pos.y) {
+                            stillValid = false;
+                            break;
+                        }
+                    }
+
+                    for (let existingFood of foods) {
+                        if (existingFood.x === pos.x && existingFood.y === pos.y) {
+                            stillValid = false;
+                            break;
+                        }
+                    }
+
+                    if (stillValid && foods.length < 25) {
+                        foods.push({
+                            x: pos.x,
+                            y: pos.y,
+                            ...cherryData
+                        });
+                    }
+                }, index * 100); // 错开出现
+            });
+
+            showPowerUpEffect(`Cherry Tree: +${cherryCount} cherries!`);
+
+            // 创建樱桃树动画
+            createCherryTreeAnimation();
+        }
+
         function showPowerUpEffect(text) {
             // 创建临时UI提示
             const effectDiv = document.createElement('div');
